---
import { getCollection, render } from "astro:content";
import PlanLayout from "@layouts/PlanLayout.astro";
import { loadThreads } from "@lib/feedback";

// One built page per artifact at /p/<id>/index.html. The cosmetic slug in shared
// URLs (/p/<id>/<slug>) is stripped at the edge by the CloudFront function, so
// routing only ever depends on <id> — the stable collection entry id (filename).
export async function getStaticPaths() {
  const plans = await getCollection("plans");
  return plans.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
// Dev: hydrate the comment layer with any saved threads. Build: always empty.
const threads = import.meta.env.DEV ? loadThreads(entry.id) : [];
---

<PlanLayout plan={entry.data} id={entry.id} threads={threads}>
  <Content />
</PlanLayout>

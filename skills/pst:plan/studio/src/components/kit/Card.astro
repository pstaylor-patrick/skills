---
// A general content card. With `tag` it becomes the "idea card" pattern: a left
// accent border, a title, and a category pill in the top-right corner (think the
// EXCESS / UNCOMMON / RARE ONE cards). `edge` colors the left border.
import Pill from "./Pill.astro";

interface Props {
  title?: string;
  subtitle?: string;
  tag?: string;
  tagTone?: "neutral" | "accent" | "success" | "warning" | "danger" | "info";
  edge?: boolean | string;
  anchor?: string;
  class?: string;
}
const {
  title,
  subtitle,
  tag,
  tagTone = "accent",
  edge = false,
  anchor,
  class: cls,
} = Astro.props;
const edgeColor = typeof edge === "string" ? edge : edge ? "var(--accent)" : "";
const style = edgeColor ? `border-left:3px solid ${edgeColor}` : "";
---

<article
  class:list={["ps-card", { edged: Boolean(edgeColor) }, cls]}
  style={style}
  data-anchor={anchor ?? title}
>
  {
    (title || tag) && (
      <header>
        <div class="titles">
          {title && <h3>{title}</h3>}
          {subtitle && <p class="sub">{subtitle}</p>}
        </div>
        {tag && (
          <Pill tone={tagTone} solid>
            {tag}
          </Pill>
        )}
      </header>
    )
  }
  <div class="body"><slot /></div>
</article>

<style>
  .ps-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  header {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
  }
  h3 {
    font-size: var(--step-1);
  }
  .sub {
    color: var(--muted);
    margin-top: 0.25rem;
    font-size: 0.95rem;
  }
  .body {
    margin-top: 0.7rem;
  }
  .body :global(> * + *) {
    margin-top: 0.5rem;
  }
  .body :global(ul) {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .body :global(ul li) {
    position: relative;
    padding-left: 1.4rem;
    color: var(--muted);
  }
  .body :global(ul li)::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 600;
  }
</style>

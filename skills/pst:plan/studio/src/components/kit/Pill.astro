---
interface Props {
  // Visual tone. `accent` uses the theme accent; the rest are semantic.
  tone?: "neutral" | "accent" | "success" | "warning" | "danger" | "info";
  solid?: boolean;
  class?: string;
}
const { tone = "neutral", solid = false, class: cls } = Astro.props;
---

<span class:list={["ps-pill", `t-${tone}`, { solid }, cls]}>
  <slot />
</span>

<style>
  .ps-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1;
    padding: 0.42em 0.7em;
    border-radius: 999px;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .t-neutral {
    background: var(--subtle);
    color: var(--muted);
    border-color: var(--border);
  }
  .t-accent {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }
  .t-success {
    background: color-mix(in srgb, #16915b 14%, transparent);
    color: #16915b;
  }
  .t-warning {
    background: color-mix(in srgb, #b97309 16%, transparent);
    color: #b97309;
  }
  .t-danger {
    background: color-mix(in srgb, #c33a3a 14%, transparent);
    color: #c33a3a;
  }
  .t-info {
    background: color-mix(in srgb, #2f6fd0 14%, transparent);
    color: #2f6fd0;
  }
  .solid.t-accent {
    background: var(--accent);
    color: var(--accent-text);
  }
  .solid {
    color: #fff;
  }
  .solid.t-success {
    background: #16915b;
  }
  .solid.t-warning {
    background: #b97309;
  }
  .solid.t-danger {
    background: #c33a3a;
  }
  .solid.t-info {
    background: #2f6fd0;
  }
</style>

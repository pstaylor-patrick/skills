---
import Icon from "./Icon.astro";
import type { IconName } from "@lib/icons";

interface Props {
  icon?: IconName;
  title: string;
  anchor?: string;
}
const { icon = "sparkle", title, anchor } = Astro.props;
---

<div class="ps-feature" data-anchor={anchor ?? title}>
  <div class="ico"><Icon name={icon} size={22} /></div>
  <h3>{title}</h3>
  <div class="body"><slot /></div>
</div>

<style>
  .ps-feature {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .ico {
    display: inline-grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 11px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    margin-bottom: 1rem;
  }
  h3 {
    font-size: var(--step-1);
  }
  .body {
    margin-top: 0.5rem;
    color: var(--muted);
  }
  .body :global(> * + *) {
    margin-top: 0.5rem;
  }
</style>

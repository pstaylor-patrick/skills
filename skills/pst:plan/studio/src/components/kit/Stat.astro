---
// One headline metric. Inside a <Stats variant="cards">, give it a `color` for
// the solid colored-card look (clay/forest/slate/ochre/plum/accent). Inside a
// <Stats variant="divided"> leave color unset for the quiet hairline cell.
interface Props {
  value: string | number;
  label: string;
  // Small italic annotation under the label (e.g. "an actual flock").
  note?: string;
  color?:
    | "clay"
    | "forest"
    | "slate"
    | "ochre"
    | "plum"
    | "accent"
    | "surface";
  anchor?: string;
}
const { value, label, note, color, anchor } = Astro.props;
const COLORS: Record<string, string> = {
  clay: "#9c4221",
  forest: "#2f5d3a",
  slate: "#395673",
  ochre: "#b08227",
  plum: "#6d3b63",
};
const isCard = color !== undefined;
const bg =
  color === "accent"
    ? "var(--accent)"
    : color === "surface"
      ? "var(--surface)"
      : color
        ? COLORS[color]
        : "var(--surface)";
const light = color === "surface" || color === undefined;
const style = `--stat-bg:${bg};--stat-fg:${light ? "var(--text)" : "#fff"};--stat-muted:${light ? "var(--muted)" : "rgba(255,255,255,.78)"}`;
---

<div
  class:list={["ps-stat", { card: isCard }]}
  style={style}
  data-anchor={anchor ?? label}
>
  <div class="value">{value}</div>
  <div class="label">{label}</div>
  {note && <div class="note">{note}</div>}
</div>

<style>
  .ps-stat {
    padding: 1.3rem 1.4rem;
    background: var(--stat-bg);
    color: var(--stat-fg);
  }
  .ps-stat.card {
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .value {
    font-family: var(--font-display);
    font-size: var(--step-4);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .label {
    margin-top: 0.55rem;
    font-weight: 560;
    font-size: 0.95rem;
  }
  .note {
    color: var(--stat-muted);
    font-size: 0.82rem;
    font-style: italic;
    margin-top: 0.1rem;
  }
</style>

---
// Figma/Vercel-preview-style click-anywhere comments. DEV ONLY: it renders
// nothing in the published static bundle, so shared artifacts stay clean. Click
// the toolbar's "Comment", then click anywhere on the page — the layer captures
// the nearest [data-anchor], section heading, a CSS selector, and the local text
// so feedback is auto-grounded. Threads persist to studio/feedback/<id>.json via
// the dev middleware; `/pst:artifact --feedback <id>` reads them back to revise.
import type { Thread } from "@lib/feedback";

interface Props {
  id: string;
  threads?: Thread[];
}
const { id, threads = [] } = Astro.props;
const isDev = import.meta.env.DEV;
---

{
  isDev && (
    <div class="ps-cl" data-id={id}>
      <div class="ps-cl-overlay" id="ps-cl-overlay" />

      <div class="ps-cl-bar" id="ps-cl-bar">
        <button type="button" id="ps-cl-toggle" class="primary">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12a8 8 0 0 1-11.6 7.1L4 20l1-5.2A8 8 0 1 1 21 12Z" />
          </svg>
          <span class="lbl">Comment</span>
        </button>
        <button type="button" id="ps-cl-review">
          Review <span class="ps-cl-count" id="ps-cl-count">0</span>
        </button>
      </div>

      <div class="ps-cl-pop" id="ps-cl-pop" hidden>
        <div class="ps-cl-pop-ctx" id="ps-cl-pop-ctx" />
        <textarea
          id="ps-cl-text"
          rows="3"
          placeholder="What should change here?"
        />
        <div class="ps-cl-pop-actions">
          <button type="button" id="ps-cl-resolve" class="ghost">
            Resolve
          </button>
          <button type="button" id="ps-cl-delete" class="ghost danger">
            Delete
          </button>
          <button type="button" id="ps-cl-save" class="primary">
            Save
          </button>
        </div>
      </div>

      <aside class="ps-cl-drawer" id="ps-cl-drawer">
        <header>
          <strong>Review</strong>
          <button type="button" id="ps-cl-close">✕</button>
        </header>
        <div class="ps-cl-list" id="ps-cl-list" />
        <footer>
          <button type="button" id="ps-cl-copy" class="primary">
            Copy feedback for Claude
          </button>
          <p class="ps-cl-hint">
            Saved to <code>feedback/{id}.json</code> — run
            <code>/pst:artifact --feedback {id}</code> to revise.
          </p>
        </footer>
      </aside>

      <div class="ps-cl-toast" id="ps-cl-toast" />

      <script
        is:inline
        define:vars={{ planId: id, initialThreads: threads }}
      >
        (function () {
          var threads = Array.isArray(initialThreads) ? initialThreads.slice() : [];
          var armed = false;
          var editingId = null;
          var saveTimer = null;

          var $ = function (s) { return document.getElementById(s); };
          var overlay = $("ps-cl-overlay");
          var bar = $("ps-cl-bar");
          var pop = $("ps-cl-pop");
          var drawer = $("ps-cl-drawer");

          function persist() {
            clearTimeout(saveTimer);
            saveTimer = setTimeout(function () {
              fetch("/api/comments?id=" + encodeURIComponent(planId), {
                method: "POST",
                headers: { "content-type": "application/json" },
                body: JSON.stringify({ id: planId, threads: threads }),
              }).catch(function () {});
            }, 250);
          }

          function uid() {
            return (
              "c" + Date.now().toString(36) + Math.random().toString(36).slice(2, 6)
            );
          }

          function selectorOf(el) {
            var parts = [];
            while (el && el.nodeType === 1 && parts.length < 4) {
              if (el.id) { parts.unshift("#" + el.id); break; }
              var name = el.tagName.toLowerCase();
              var p = el.parentNode;
              if (p) {
                var sibs = Array.prototype.filter.call(p.children, function (c) {
                  return c.tagName === el.tagName;
                });
                if (sibs.length > 1) {
                  name += ":nth-of-type(" + (sibs.indexOf(el) + 1) + ")";
                }
              }
              parts.unshift(name);
              el = el.parentNode;
            }
            return parts.join(" > ");
          }

          function contextOf(el) {
            var anchorEl = el.closest("[data-anchor]");
            var sectionEl = el.closest("section, header, article");
            var heading = sectionEl && sectionEl.querySelector("h1,h2,h3");
            var src = anchorEl || el;
            var snippet = (src.textContent || "").replace(/\s+/g, " ").trim();
            return {
              anchor: anchorEl ? anchorEl.getAttribute("data-anchor") : null,
              section: heading ? heading.textContent.replace(/\s+/g, " ").trim() : null,
              selector: selectorOf(el),
              snippet: snippet ? snippet.slice(0, 240) : null,
            };
          }

          function setArmed(on) {
            armed = on;
            document.body.classList.toggle("ps-cl-arming", on);
            var t = $("ps-cl-toggle");
            t.classList.toggle("active", on);
            t.querySelector(".lbl").textContent = on ? "Click anywhere…" : "Comment";
          }

          function onDocClick(e) {
            if (!armed) return;
            if (e.target.closest(".ps-cl")) return;
            e.preventDefault();
            e.stopPropagation();
            var ctx = contextOf(e.target);
            var t = {
              id: uid(),
              x: Math.round(e.pageX),
              y: Math.round(e.pageY),
              anchor: ctx.anchor,
              section: ctx.section,
              selector: ctx.selector,
              snippet: ctx.snippet,
              viewport: window.innerWidth,
              comment: "",
              status: "open",
              createdAt: new Date().toISOString(),
            };
            threads.push(t);
            setArmed(false);
            renderPins();
            openComposer(t.id);
          }

          function sizeOverlay() {
            overlay.style.height =
              Math.max(
                document.documentElement.scrollHeight,
                document.body.scrollHeight
              ) + "px";
          }

          function renderPins() {
            sizeOverlay();
            overlay.innerHTML = "";
            threads.forEach(function (t, i) {
              var pin = document.createElement("button");
              pin.type = "button";
              pin.className = "ps-cl-pin" + (t.status === "resolved" ? " done" : "");
              pin.style.left = t.x + "px";
              pin.style.top = t.y + "px";
              pin.textContent = String(i + 1);
              pin.title = t.comment || "(empty)";
              pin.addEventListener("click", function (ev) {
                ev.stopPropagation();
                openComposer(t.id);
              });
              overlay.appendChild(pin);
            });
            updateCount();
          }

          function updateCount() {
            var n = threads.filter(function (t) {
              return (t.comment || "").trim() && t.status !== "resolved";
            }).length;
            $("ps-cl-count").textContent = String(n);
          }

          function findThread(tid) {
            for (var i = 0; i < threads.length; i++) {
              if (threads[i].id === tid) return threads[i];
            }
            return null;
          }

          function openComposer(tid) {
            var t = findThread(tid);
            if (!t) return;
            editingId = tid;
            var ctxLabel = t.anchor || t.section || "General";
            $("ps-cl-pop-ctx").textContent =
              ctxLabel + (t.snippet ? " — “" + t.snippet.slice(0, 80) + "”" : "");
            var ta = $("ps-cl-text");
            ta.value = t.comment || "";
            pop.hidden = false;
            var top = Math.max(12, t.y - window.scrollY - 30);
            var left = Math.min(window.innerWidth - 340, t.x + 16);
            pop.style.top = top + "px";
            pop.style.left = Math.max(12, left) + "px";
            ta.focus();
          }

          function closeComposer() {
            if (editingId) {
              var t = findThread(editingId);
              if (t && !(t.comment || "").trim() && t.status === "open") {
                threads = threads.filter(function (x) { return x.id !== editingId; });
                renderPins();
              }
            }
            pop.hidden = true;
            editingId = null;
            persist();
          }

          function saveComposer() {
            var t = findThread(editingId);
            if (t) { t.comment = $("ps-cl-text").value.trim(); }
            pop.hidden = true;
            editingId = null;
            renderPins();
            persist();
            toast("Saved");
          }

          function renderDrawer() {
            var list = $("ps-cl-list");
            list.innerHTML = "";
            if (!threads.length) {
              list.innerHTML = '<p class="ps-cl-empty">No comments yet. Click “Comment”, then click anywhere on the page.</p>';
              return;
            }
            threads.forEach(function (t, i) {
              var item = document.createElement("div");
              item.className = "ps-cl-item" + (t.status === "resolved" ? " done" : "");
              var label = t.anchor || t.section || "General";
              item.innerHTML =
                '<div class="ps-cl-item-h"><span class="n">' + (i + 1) +
                '</span><span class="a">' + escapeHtml(label) + "</span></div>" +
                '<p class="c">' + (escapeHtml(t.comment) || "<em>(empty)</em>") + "</p>";
              item.addEventListener("click", function () { openComposer(t.id); });
              list.appendChild(item);
            });
          }

          function escapeHtml(s) {
            return (s || "").replace(/[&<>"]/g, function (c) {
              return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
            });
          }

          function copyForClaude() {
            var live = threads.filter(function (t) {
              return (t.comment || "").trim() && t.status !== "resolved";
            });
            var text;
            if (!live.length) {
              text =
                'I reviewed the artifact "' + planId +
                '" and accept it as written — no changes. Proceed.';
            } else {
              text =
                "Revise the artifact \"" + planId + "\" with this review feedback, " +
                "then I'll re-run /pst:artifact. " + live.length + " comment(s):\n\n" +
                live
                  .map(function (t, i) {
                    var loc = t.anchor || t.section || "General";
                    var ctx = t.snippet ? '\n   context: "' + t.snippet + '"' : "";
                    return (i + 1) + ". [" + loc + "]" + ctx + "\n   → " + t.comment;
                  })
                  .join("\n\n");
            }
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(text).then(
                function () { toast("Copied — paste into Claude Code"); },
                function () { toast("Copy failed — see console"); console.log(text); }
              );
            } else {
              console.log(text);
              toast("Logged to console");
            }
          }

          var toastTimer;
          function toast(msg) {
            var el = $("ps-cl-toast");
            el.textContent = msg;
            el.classList.add("show");
            clearTimeout(toastTimer);
            toastTimer = setTimeout(function () { el.classList.remove("show"); }, 2200);
          }

          // wire up
          $("ps-cl-toggle").addEventListener("click", function () { setArmed(!armed); });
          $("ps-cl-review").addEventListener("click", function () {
            renderDrawer();
            drawer.classList.add("open");
          });
          $("ps-cl-close").addEventListener("click", function () {
            drawer.classList.remove("open");
          });
          $("ps-cl-save").addEventListener("click", saveComposer);
          $("ps-cl-text").addEventListener("keydown", function (e) {
            if ((e.metaKey || e.ctrlKey) && e.key === "Enter") saveComposer();
            if (e.key === "Escape") closeComposer();
          });
          $("ps-cl-resolve").addEventListener("click", function () {
            var t = findThread(editingId);
            if (t) { t.status = t.status === "resolved" ? "open" : "resolved"; }
            pop.hidden = true; editingId = null;
            renderPins(); renderDrawer(); persist();
          });
          $("ps-cl-delete").addEventListener("click", function () {
            threads = threads.filter(function (x) { return x.id !== editingId; });
            pop.hidden = true; editingId = null;
            renderPins(); renderDrawer(); persist();
          });
          $("ps-cl-copy").addEventListener("click", copyForClaude);
          document.addEventListener("click", onDocClick, true);
          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && armed) setArmed(false);
            if (e.key === "c" && !/input|textarea/i.test(document.activeElement.tagName)) {
              setArmed(!armed);
            }
          });
          window.addEventListener("resize", renderPins);

          renderPins();
        })();
      </script>
    </div>
  )
}

<style is:global>
  .ps-cl-arming,
  .ps-cl-arming * {
    cursor: crosshair !important;
  }
  .ps-cl-overlay {
    position: absolute;
    inset: 0 0 auto 0;
    pointer-events: none;
    z-index: 40;
  }
  .ps-cl-pin {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50% 50% 50% 2px;
    background: var(--accent, #b4541f);
    color: #fff;
    border: 2px solid #fff;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.28);
    font: 600 0.75rem/1 var(--font-body, sans-serif);
    cursor: pointer;
    pointer-events: auto;
    display: grid;
    place-items: center;
  }
  .ps-cl-pin.done {
    background: #16915b;
    opacity: 0.65;
  }
  .ps-cl-bar {
    position: fixed;
    bottom: 1.2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.4rem;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 999px;
    padding: 0.35rem;
    box-shadow: 0 10px 34px -10px rgba(0, 0, 0, 0.35);
    z-index: 60;
    font-family: var(--font-body, system-ui);
  }
  .ps-cl-bar button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 0;
    background: transparent;
    color: #1f1b16;
    font-size: 0.85rem;
    font-weight: 560;
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    cursor: pointer;
  }
  .ps-cl-bar button:hover {
    background: rgba(0, 0, 0, 0.05);
  }
  .ps-cl-bar button.primary.active {
    background: var(--accent, #b4541f);
    color: #fff;
  }
  .ps-cl-count {
    display: inline-grid;
    place-items: center;
    min-width: 1.3rem;
    height: 1.3rem;
    padding: 0 0.35rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.08);
    font-size: 0.72rem;
  }
  .ps-cl-pop {
    position: fixed;
    width: 320px;
    max-width: calc(100vw - 24px);
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    box-shadow: 0 16px 44px -12px rgba(0, 0, 0, 0.4);
    padding: 0.85rem;
    z-index: 70;
    font-family: var(--font-body, system-ui);
  }
  .ps-cl-pop-ctx {
    font-size: 0.74rem;
    color: #6b6155;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  .ps-cl-pop textarea {
    width: 100%;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 8px;
    padding: 0.5rem 0.6rem;
    resize: vertical;
    font-size: 0.9rem;
    box-sizing: border-box;
  }
  .ps-cl-pop-actions {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.5rem;
    justify-content: flex-end;
  }
  .ps-cl-pop-actions button {
    border: 0;
    border-radius: 8px;
    padding: 0.45rem 0.8rem;
    font-size: 0.82rem;
    font-weight: 560;
    cursor: pointer;
  }
  .ps-cl-pop-actions .ghost {
    background: transparent;
    color: #6b6155;
  }
  .ps-cl-pop-actions .ghost.danger {
    color: #c33a3a;
    margin-right: auto;
  }
  .ps-cl-pop-actions .primary {
    background: var(--accent, #b4541f);
    color: #fff;
  }
  .ps-cl-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 340px;
    max-width: 90vw;
    height: 100vh;
    background: #fff;
    border-left: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: -12px 0 40px -16px rgba(0, 0, 0, 0.3);
    transform: translateX(100%);
    transition: transform 0.22s ease;
    z-index: 65;
    display: flex;
    flex-direction: column;
    font-family: var(--font-body, system-ui);
  }
  .ps-cl-drawer.open {
    transform: translateX(0);
  }
  .ps-cl-drawer header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .ps-cl-drawer header button {
    border: 0;
    background: none;
    font-size: 1rem;
    cursor: pointer;
    color: #6b6155;
  }
  .ps-cl-list {
    flex: 1;
    overflow: auto;
    padding: 0.6rem;
  }
  .ps-cl-empty {
    color: #6b6155;
    font-size: 0.88rem;
    padding: 1rem;
  }
  .ps-cl-item {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    padding: 0.7rem 0.8rem;
    margin-bottom: 0.5rem;
    cursor: pointer;
  }
  .ps-cl-item:hover {
    border-color: var(--accent, #b4541f);
  }
  .ps-cl-item.done {
    opacity: 0.55;
  }
  .ps-cl-item-h {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.3rem;
  }
  .ps-cl-item-h .n {
    display: inline-grid;
    place-items: center;
    width: 1.3rem;
    height: 1.3rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent, #b4541f) 14%, transparent);
    color: var(--accent, #b4541f);
    font-size: 0.72rem;
    font-weight: 600;
  }
  .ps-cl-item-h .a {
    font-size: 0.8rem;
    font-weight: 600;
  }
  .ps-cl-item .c {
    font-size: 0.86rem;
    color: #3a342c;
    margin: 0;
  }
  .ps-cl-drawer footer {
    padding: 0.9rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .ps-cl-drawer footer .primary {
    width: 100%;
    border: 0;
    border-radius: 9px;
    padding: 0.6rem;
    background: var(--accent, #b4541f);
    color: #fff;
    font-weight: 600;
    cursor: pointer;
  }
  .ps-cl-hint {
    font-size: 0.72rem;
    color: #6b6155;
    margin: 0.6rem 0 0;
    line-height: 1.5;
  }
  .ps-cl-hint code {
    font-family: var(--font-mono, monospace);
    background: rgba(0, 0, 0, 0.05);
    padding: 0.05em 0.3em;
    border-radius: 4px;
  }
  .ps-cl-toast {
    position: fixed;
    bottom: 4.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: #1f1b16;
    color: #fff;
    padding: 0.5rem 0.9rem;
    border-radius: 8px;
    font-size: 0.82rem;
    opacity: 0;
    pointer-events: none;
    transition: all 0.2s ease;
    z-index: 80;
    font-family: var(--font-body, system-ui);
  }
  .ps-cl-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

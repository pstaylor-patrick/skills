---
// A titled content band. `anchor` makes the whole section commentable. Provide
// `aside` for the editorial header treatment: title on the left, a hairline
// filling the gap, and a small-caps annotation on the right
// (e.g. "Big Stockpiles ——— USE THESE FIRST"). `wide` for full-bleed grids,
// `tint` to lift onto a subtle surface.
interface Props {
  id?: string;
  title?: string;
  eyebrow?: string;
  lede?: string;
  aside?: string;
  anchor?: string;
  wide?: boolean;
  tint?: boolean;
  class?: string;
}
const {
  id,
  title,
  eyebrow,
  lede,
  aside,
  anchor,
  wide,
  tint,
  class: cls,
} = Astro.props;
const ruled = Boolean(aside);
---

<section
  id={id}
  class:list={["ps-section", { tint }, cls]}
  data-anchor={anchor ?? title ?? id}
>
  <div class:list={["container", { "container-wide": wide }]}>
    {
      (eyebrow || title || lede || aside) && (
        <header class:list={["ps-section-head", { ruled }]}>
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {(title || aside) && (
            <div class="titlerow">
              {title && <h2>{title}</h2>}
              {ruled && <span class="rule" aria-hidden="true" />}
              {aside && <span class="aside">{aside}</span>}
            </div>
          )}
          {lede && <p class="lede">{lede}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>

<style>
  .ps-section {
    padding-block: clamp(2.6rem, 6vw, 5rem);
  }
  .ps-section.tint {
    background: var(--subtle);
  }
  .ps-section-head {
    margin-bottom: clamp(1.6rem, 4vw, 2.6rem);
  }
  .ps-section-head:not(.ruled) {
    max-width: 44rem;
  }
  .ps-section-head h2 {
    font-size: var(--step-3);
  }
  .ps-section-head .eyebrow {
    margin-bottom: 0.5rem;
  }
  .titlerow {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .rule {
    flex: 1;
    height: 1px;
    background: var(--border);
    transform: translateY(-0.25em);
  }
  .aside {
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }
  .lede {
    margin-top: 0.8rem;
    font-size: var(--step-1);
    color: var(--muted);
    line-height: 1.55;
    max-width: 46rem;
    text-wrap: pretty;
  }
</style>

---
import Icon from "./Icon.astro";
import type { IconName } from "@lib/icons";

interface Props {
  tone?: "note" | "tip" | "warning" | "danger";
  title?: string;
  icon?: IconName;
  anchor?: string;
}
const { tone = "note", title, icon, anchor } = Astro.props;
const fallback: Record<string, IconName> = {
  note: "info",
  tip: "lightbulb",
  warning: "warning",
  danger: "shield",
};
const iconName = icon ?? fallback[tone];
---

<aside class:list={["ps-callout", `t-${tone}`]} data-anchor={anchor ?? title}>
  <div class="ico"><Icon name={iconName} size={20} /></div>
  <div class="body">
    {title && <p class="title">{title}</p>}
    <div class="content"><slot /></div>
  </div>
</aside>

<style>
  .ps-callout {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    padding: 1.1rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
    border-left-width: 3px;
  }
  .ico {
    color: var(--accent);
    margin-top: 0.1rem;
  }
  .title {
    font-weight: 650;
    font-family: var(--font-display);
    margin-bottom: 0.2rem;
  }
  .content {
    color: var(--muted);
    font-size: 0.95em;
  }
  .content :global(> * + *) {
    margin-top: 0.5rem;
  }
  .t-tip {
    border-left-color: #16915b;
  }
  .t-tip .ico {
    color: #16915b;
  }
  .t-warning {
    border-left-color: #b97309;
  }
  .t-warning .ico {
    color: #b97309;
  }
  .t-danger {
    border-left-color: #c33a3a;
  }
  .t-danger .ico {
    color: #c33a3a;
  }
  .t-note {
    border-left-color: var(--accent);
  }
</style>

---
interface Props {
  min?: string;
  class?: string;
}
const { min = "18rem", class: cls } = Astro.props;
---

<div class:list={["ps-cardgrid", cls]} style={`--min:${min}`}><slot /></div>

<style>
  .ps-cardgrid {
    display: grid;
    gap: clamp(1rem, 2.5vw, 1.5rem);
    grid-template-columns: repeat(auto-fit, minmax(var(--min), 1fr));
  }
</style>

---
import { ICONS, type IconName } from "@lib/icons";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}
const { name, size = 22, class: cls } = Astro.props;
const inner = ICONS[name] ?? ICONS.sparkle;
---

<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>

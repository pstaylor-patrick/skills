---
import "../lib/fonts";
import "../styles/global.css";
import { getCollection } from "astro:content";
import { THEMES, themeVars, type ThemeKey } from "@lib/theme";

const plans = (await getCollection("plans")).sort((a, b) => {
  const ad = (a.data.updatedAt ?? a.data.createdAt ?? new Date(0)).valueOf();
  const bd = (b.data.updatedAt ?? b.data.createdAt ?? new Date(0)).valueOf();
  return bd - ad;
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Artifacts</title>
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon-256x256.png" />
  </head>
  <body>
    <header class="hd container">
      <p class="eyebrow">Private artifacts</p>
      <h1>The studio</h1>
      <p class="sub">
        Interactive plans, briefs, and prototypes — each one a self-contained,
        no-index artifact you can share with a link.
      </p>
    </header>

    <main class="container">
      {
        plans.length === 0 ? (
          <p class="empty">
            No artifacts yet. Run <code>/pst:artifact</code> to create one.
          </p>
        ) : (
          <ul class="grid">
            {plans.map((p) => {
              const t = THEMES[p.data.theme as ThemeKey] ?? THEMES.editorial;
              const accent = p.data.accent || t.accent;
              return (
                <li>
                  <a
                    href={`/p/${p.id}/${p.data.permalink}`}
                    style={themeVars(p.data.theme as ThemeKey, p.data.accent)}
                  >
                    <span class="swatch" style={`background:${accent}`} />
                    <div class="body">
                      {p.data.eyebrow && <p class="card-eyebrow">{p.data.eyebrow}</p>}
                      <h2>{p.data.title}</h2>
                      {p.data.subtitle && <p class="card-sub">{p.data.subtitle}</p>}
                      <div class="foot">
                        <code>/p/{p.id}</code>
                        {p.data.status && <span class="chip">{p.data.status}</span>}
                      </div>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }
    </main>

    <style>
      body {
        background: var(--bg);
        color: var(--text);
      }
      .hd {
        padding-block: clamp(3rem, 8vw, 5.5rem) 1.5rem;
      }
      .hd h1 {
        font-size: var(--step-4);
        margin-top: 0.4rem;
      }
      .sub {
        margin-top: 0.9rem;
        color: var(--muted);
        font-size: var(--step-1);
        max-width: 44rem;
      }
      .empty {
        padding: 3rem 0;
        color: var(--muted);
      }
      .grid {
        list-style: none;
        padding: 0 0 4rem;
        display: grid;
        gap: 1.2rem;
        grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
      }
      .grid a {
        display: block;
        text-decoration: none;
        color: var(--text);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease;
      }
      .grid a:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
      }
      .swatch {
        display: block;
        height: 6px;
      }
      .body {
        padding: 1.3rem 1.4rem 1.4rem;
      }
      .card-eyebrow {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.4rem;
      }
      .body h2 {
        font-size: var(--step-2);
      }
      .card-sub {
        margin-top: 0.4rem;
        color: var(--muted);
        font-size: 0.92rem;
      }
      .foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1.1rem;
      }
      .foot code {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--muted);
      }
      .chip {
        font-size: 0.68rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--accent);
        background: color-mix(in srgb, var(--accent) 12%, transparent);
        padding: 0.25em 0.6em;
        border-radius: 999px;
      }
    </style>
  </body>
</html>

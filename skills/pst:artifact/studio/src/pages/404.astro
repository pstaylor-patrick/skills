---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Not found</title>
  </head>
  <body>
    <main class="wrap">
      <p class="eyebrow">404</p>
      <h1>Nothing here</h1>
      <p>This artifact doesn’t exist, or the link is wrong. Only the id in the
        URL matters — the words after it are decorative.</p>
      <a href="/">← Back to the studio</a>
    </main>
    <style>
      .wrap {
        max-width: 32rem;
        margin: 18vh auto;
        padding: 0 1.5rem;
        text-align: center;
      }
      h1 {
        font-size: var(--step-4);
        margin: 0.3rem 0 1rem;
      }
      p {
        color: var(--muted);
      }
      a {
        display: inline-block;
        margin-top: 1.5rem;
        font-weight: 560;
      }
    </style>
  </body>
</html>
